# =============================================================================
# Matrix Share SaaS — 环境变量配置说明
# 复制此文件为 .env，填入真实值即可运行
# =============================================================================

# ── 服务基础 ──
PORT=3000
NODE_ENV=development                          # development | production
APP_DOMAIN=localhost:5173                     # 前端域名（dev=localhost:5173, prod=yourdomain.com）
JWT_SECRET=change-this-to-a-random-secret     # JWT 签名密钥（生产环境务必更换）
REDIS_URL=redis://127.0.0.1:6379              # 生产环境需部署 Redis
DATABASE_URL="file:./dev.db"                   # dev=SQLite, prod=postgresql://user:pass@host:5432/db

# 🔑 Token 加密密钥（必须 32 位字符，生产环境务必更换）
TOKEN_ENCRYPT_KEY=your-secure-32-character-key-here

# ☁️ 阿里云 OSS（视频存储，朋友自行配置）
ALI_ACCESS_KEY_ID=
ALI_ACCESS_KEY_SECRET=
ALI_OSS_REGION=oss-cn-beijing
ALI_OSS_BUCKET=

# 📕 小红书开放平台
RED_CLIENT_ID=
RED_CLIENT_SECRET=
RED_REDIRECT_URI=https://api.yourdomain.com/api/oauth/red/callback

# 🎵 抖音开放平台
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=https://api.yourdomain.com/api/oauth/douyin/callback

# 📹 快手开放平台
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
KUAISHOU_REDIRECT_URI=https://api.yourdomain.com/api/oauth/kuaishou/callback

# 📺 B站开放平台
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=
BILIBILI_REDIRECT_URI=https://api.yourdomain.com/api/oauth/bilibili/callback

# 🟢 微信第三方平台
WX_COMPONENT_APPID=
WX_COMPONENT_APPSECRET=
WX_COMPONENT_TOKEN=
WX_COMPONENT_AES_KEY=
WX_COMPONENT_REDIRECT_URI=https://api.yourdomain.com/api/oauth/wechat/callback

# 💳 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_RETURN_URL=https://yourdomain.com/dashboard/billing?pay=success
ALIPAY_NOTIFY_URL=https://api.yourdomain.com/v1/payment/alipay/notify

# 🟢 微信支付 APIv3
WX_MCH_ID=
WX_MCH_SERIAL_NO=
WX_API_V3_KEY=
WX_PRIVATE_KEY=
WX_PAY_NOTIFY_URL=https://api.yourdomain.com/v1/payment/wechat/notify
